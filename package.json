{
  "name": "trashy",
  "version": "1.0.0",
  "description": "临时垃圾桶存储工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite"
  },
  "keywords": [
    "electron",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.trashy.app",
    "productName": "Trashy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/11 (1311).png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true
    },
    "publish": {
      "provider": "github",
      "owner": "dog-shit-0708",
      "repo": "Trashy"
    }
  },
  "config": {
    "electron_mirror": "https://cdn.npmmirror.com/binaries/electron/"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
